<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:models="using:EdgeStudio.Shared.Models"
             x:Class="EdgeStudio.Views.Controls.DetailBottomBar"
             x:CompileBindings="False">

    <UserControl.Styles>
        <!-- Plain button — no chrome, no hover background, blends into the bar like SwiftUI .buttonStyle(.plain) -->
        <Style Selector="Button.BarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Panel VerticalAlignment="Bottom" HorizontalAlignment="Stretch">

        <!-- EXPANDED STATE: full-width bar, connections left, chevron right -->
        <Border x:Name="ExpandedBar"
                HorizontalAlignment="Stretch"
                Background="#CC1A1F2E"
                CornerRadius="10"
                BoxShadow="0 -2 12 2 #40000000"
                Margin="12,0,12,12">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="44">

                <!-- Left: connections button with flyout -->
                <Button Grid.Column="0"
                        x:Name="ConnectionsButton"
                        Classes="BarButton"
                        Padding="20,12"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center">
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <Border Background="#1E2433"
                                    CornerRadius="10"
                                    BoxShadow="0 4 16 2 #60000000"
                                    MinWidth="190"
                                    Padding="0,4,0,8">
                                <StackPanel>
                                    <TextBlock Text="Connections"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.5"
                                               Margin="14,8,14,4"/>
                                    <Separator Opacity="0.2" Margin="0,0,0,4"/>

                                    <!-- Active transports list -->
                                    <ItemsControl x:Name="TransportsList"
                                                  ItemsSource="{Binding ActiveTransports}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="models:TransportInfo">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8"
                                                            Margin="14,5,14,0">
                                                    <Border Width="8" Height="8"
                                                            CornerRadius="4"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding DotBrush}"/>
                                                    <TextBlock FontSize="13"
                                                               Foreground="White"
                                                               VerticalAlignment="Center">
                                                        <Run Text="{Binding Name}"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding Count}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- No connections fallback -->
                                    <StackPanel x:Name="NoConnectionsPanel"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="14,6">
                                        <avalonia:MaterialIcon Kind="WifiOff"
                                                               Width="16" Height="16"
                                                               Foreground="White"
                                                               Opacity="0.45"
                                                               VerticalAlignment="Center"/>
                                        <TextBlock Text="No Active Connections"
                                                   Foreground="White"
                                                   Opacity="0.55"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <avalonia:MaterialIcon Kind="AccessPoint"
                                               Width="16" Height="16"
                                               Foreground="White"
                                               Opacity="0.65"
                                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionCountText"
                                   FontSize="14"
                                   FontFamily="Monospace"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Center: empty spacer -->
                <Panel Grid.Column="1"/>

                <!-- Right: collapse button -->
                <Button Grid.Column="2"
                        Classes="BarButton"
                        Padding="20,12"
                        VerticalAlignment="Center"
                        Click="CollapseButton_Click">
                    <avalonia:MaterialIcon Kind="ChevronDoubleRight"
                                           Width="16" Height="16"
                                           Foreground="White"
                                           Opacity="0.55"/>
                </Button>

            </Grid>
        </Border>

        <!-- COLLAPSED STATE: small pill anchored to right -->
        <Border x:Name="CollapsedBar"
                IsVisible="False"
                HorizontalAlignment="Right"
                Background="#CC1A1F2E"
                CornerRadius="10"
                BoxShadow="0 -2 12 2 #40000000"
                Margin="0,0,12,12">
            <Button Classes="BarButton"
                    Padding="20,12"
                    VerticalAlignment="Center"
                    Click="ExpandButton_Click">
                <avalonia:MaterialIcon Kind="ChevronDoubleLeft"
                                       Width="16" Height="16"
                                       Foreground="White"
                                       Opacity="0.55"/>
            </Button>
        </Border>

    </Panel>

</UserControl>
