<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="using:SukiUI.Controls"
                 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
                 mc:Ignorable="d"
                 d:DesignWidth="480"
                 d:DesignHeight="340"
                 x:Class="EdgeStudio.Views.QrCodeImportWindow"
                 Title="Import from QR Code"
                 Width="480"
                 Height="340"
                 WindowStartupLocation="CenterOwner"
                 CanResize="False"
                 BackgroundStyle="Flat">

    <Border Padding="24">
        <StackPanel Spacing="16">

            <TextBlock Text="Import Database Configuration"
                       FontSize="18"
                       FontWeight="Bold"/>

            <!-- File import -->
            <Button x:Name="OpenFileButton"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,10"
                    Background="{DynamicResource DittoCardSurface}"
                    CornerRadius="6"
                    Click="OpenFile_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <materialIcons:MaterialIcon Kind="ImageSearch" Width="18" Height="18"/>
                    <TextBlock Text="Open QR Code Image (.png, .jpg, .bmp)"/>
                </StackPanel>
            </Button>

            <!-- Divider -->
            <Grid ColumnDefinitions="*,Auto,*" VerticalAlignment="Center">
                <Border Grid.Column="0" Height="1" Background="{DynamicResource DittoCardSurface}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="or" Margin="12,0" Opacity="0.6" FontSize="12"/>
                <Border Grid.Column="2" Height="1" Background="{DynamicResource DittoCardSurface}" VerticalAlignment="Center"/>
            </Grid>

            <!-- Paste payload -->
            <StackPanel Spacing="6">
                <TextBlock Text="Paste EDS2 payload:" FontSize="13" Opacity="0.8"/>
                <TextBox x:Name="PasteTextBox"
                         Watermark="EDS2:..."
                         FontFamily="Consolas"
                         FontSize="12"
                         Height="64"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>
                <Button HorizontalAlignment="Right"
                        Padding="16,8"
                        Background="{DynamicResource DittoAccent}"
                        Foreground="{DynamicResource DittoJetBlack}"
                        CornerRadius="6"
                        Click="ImportPaste_Click">
                    <TextBlock Text="Import" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- Status message -->
            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       FontSize="13"
                       IsVisible="False"/>

        </StackPanel>
    </Border>
</suki:SukiWindow>
