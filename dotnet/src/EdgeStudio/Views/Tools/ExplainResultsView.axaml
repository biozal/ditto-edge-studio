<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="300"
             x:Class="EdgeStudio.Views.Tools.ExplainResultsView"
             x:DataType="vm:ExplainResultsViewModel">

    <Grid Margin="10">
        <!-- Explain Content -->
        <Border
                Background="#1e2837"
                CornerRadius="8"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding ExplainText}"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#d4d4d4"
                           TextWrapping="Wrap"
                           LineHeight="20"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
