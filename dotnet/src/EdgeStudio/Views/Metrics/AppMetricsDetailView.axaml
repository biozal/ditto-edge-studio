<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             xmlns:controls="using:EdgeStudio.Views.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Metrics.AppMetricsDetailView"
             x:DataType="vm:AppMetricsViewModel"
             x:CompileBindings="True">

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top"
                Padding="16,10"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="App Metrics"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding LastUpdatedText}"
                           FontSize="11"
                           Opacity="0.6"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Button Grid.Column="2"
                        Command="{Binding RefreshCommand}"
                        Padding="8,4"
                        ToolTip.Tip="Refresh metrics">
                    <materialIcons:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- Loading state -->
        <StackPanel DockPanel.Dock="Top"
                    IsVisible="{Binding CurrentSnapshot, Converter={x:Static ObjectConverters.IsNull}}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="24">
            <materialIcons:MaterialIcon Kind="ChartBox"
                                        Width="48"
                                        Height="48"
                                        Opacity="0.2"
                                        HorizontalAlignment="Center"/>
            <TextBlock Text="Loading metrics..."
                       Opacity="0.6"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Metrics content via DataTemplate to safely handle nullable -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ContentControl Content="{Binding CurrentSnapshot}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="{x:Type models:AppMetricsSnapshot}">
                        <StackPanel Margin="16" Spacing="16">

                            <!-- Process Section -->
                            <TextBlock Text="PROCESS"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Margin="4,0,0,0"/>
                            <WrapPanel>
                                <controls:MetricCard Title="Resident Memory" Value="{Binding ResidentMemoryFormatted}"/>
                                <controls:MetricCard Title="Virtual Memory" Value="{Binding VirtualMemoryFormatted}"/>
                                <controls:MetricCard Title="CPU Time" Value="{Binding CpuTimeFormatted}"/>
                                <controls:MetricCard Title="Open Handles" Value="{Binding OpenHandleCount}"/>
                                <controls:MetricCard Title="Uptime" Value="{Binding UptimeFormatted}"/>
                            </WrapPanel>

                            <!-- Queries Section -->
                            <TextBlock Text="QUERIES"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Margin="4,8,0,0"/>
                            <WrapPanel>
                                <controls:MetricCard Title="Total Queries" Value="{Binding TotalQueryCount}"/>
                                <controls:MetricCard Title="Avg Latency" Value="{Binding AvgLatencyFormatted}"/>
                                <controls:MetricCard Title="Last Latency" Value="{Binding LastLatencyFormatted}"/>
                            </WrapPanel>

                            <!-- Storage Section -->
                            <TextBlock Text="STORAGE"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Margin="4,8,0,0"/>
                            <WrapPanel>
                                <controls:MetricCard Title="Store" Value="{Binding StoreBytesFormatted}"/>
                                <controls:MetricCard Title="Replication" Value="{Binding ReplicationBytesFormatted}"/>
                                <controls:MetricCard Title="Attachments" Value="{Binding AttachmentsBytesFormatted}"/>
                                <controls:MetricCard Title="Auth" Value="{Binding AuthBytesFormatted}"/>
                                <controls:MetricCard Title="WAL / SHM" Value="{Binding WalShmBytesFormatted}"/>
                                <controls:MetricCard Title="Logging" Value="{Binding LogsBytesFormatted}"/>
                                <controls:MetricCard Title="Other" Value="{Binding OtherBytesFormatted}"/>
                                <controls:MetricCard Title="Total" Value="{Binding TotalStorageBytesFormatted}"/>
                            </WrapPanel>

                            <!-- Collection Breakdown Section (only shown when data is available) -->
                            <StackPanel IsVisible="{Binding HasCollectionBreakdown}" Spacing="4">
                                <TextBlock Text="{Binding CollectionBreakdownHeader}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Opacity="0.5"
                                           Margin="4,8,0,0"/>
                                <ItemsControl ItemsSource="{Binding CollectionBreakdown}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:CollectionStorageInfo}">
                                            <controls:MetricCard Title="{Binding CollectionName}"
                                                                 Value="{Binding EstimatedBytesFormatted}"
                                                                 Subtitle="{Binding DocumentCountFormatted}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
