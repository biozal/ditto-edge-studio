<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
                 x:Class="EdgeStudio.Views.StudioView.ImportDataWindow"
                 Title="Import JSON Data"
                 Width="500" Height="520"
                 CanResize="False"
                 WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24" Spacing="20">

        <!-- File Selection -->
        <StackPanel Spacing="8">
            <TextBlock Text="Select JSON File" FontWeight="SemiBold" FontSize="16"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Choose File..."
                        x:Name="ChooseFileButton"
                        Click="ChooseFile_Click"
                        Margin="8,0,0,0"/>
                <TextBlock x:Name="FileNameText"
                           Text="No file selected"
                           VerticalAlignment="Center"
                           Opacity="0.6"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </StackPanel>

        <!-- Target Collection -->
        <StackPanel Spacing="8">
            <TextBlock Text="Target Collection" FontWeight="SemiBold" FontSize="16"/>
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <RadioButton x:Name="ExistingCollectionRadio"
                                 Content="Existing Collection"
                                 IsChecked="True"
                                 Click="CollectionToggle_Click"/>
                    <RadioButton x:Name="NewCollectionRadio"
                                 Content="New Collection"
                                 Click="CollectionToggle_Click"/>
                </StackPanel>

                <ComboBox x:Name="CollectionComboBox"
                          PlaceholderText="Select a collection..."
                          HorizontalAlignment="Stretch"/>
                <TextBox x:Name="NewCollectionTextBox"
                         Watermark="New collection name"
                         IsVisible="False"/>
            </StackPanel>
        </StackPanel>

        <!-- Insert Type -->
        <StackPanel Spacing="8">
            <TextBlock Text="Insert Type" FontWeight="SemiBold" FontSize="16"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ToggleSwitch x:Name="InitialInsertToggle" OffContent="Regular Insert" OnContent="Initial Insert"/>
            </StackPanel>
        </StackPanel>

        <!-- Status area -->
        <StackPanel x:Name="StatusPanel" Spacing="8" IsVisible="False">
            <TextBlock Text="Status" FontWeight="SemiBold" FontSize="16"/>
            <ProgressBar x:Name="ImportProgressBar"
                         Minimum="0" Maximum="100"
                         IsVisible="False"/>
            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       FontSize="14"/>
        </StackPanel>

        <!-- Buttons -->
        <DockPanel Margin="0,12,0,0">
            <Button DockPanel.Dock="Left" Content="Cancel"
                    x:Name="CancelButton"
                    Click="Cancel_Click"/>
            <Button DockPanel.Dock="Right" Content="Import"
                    x:Name="ImportButton"
                    Click="Import_Click"
                    HorizontalAlignment="Right"
                    Classes="accent"/>
        </DockPanel>

    </StackPanel>
</suki:SukiWindow>
