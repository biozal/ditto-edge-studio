<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:inspector="using:EdgeStudio.Views.StudioView.Inspector"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Details.QueryMetricsDetailView"
             x:DataType="vm:QueryMetricsViewModel"
             x:CompileBindings="True">

    <Grid ColumnDefinitions="0.4*,Auto,0.6*">

        <!-- Left: list panel -->
        <DockPanel Grid.Column="0">
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    Padding="12,8"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Query Metrics"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding RecordCountText}"
                               FontSize="12"
                               Opacity="0.6"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Button Grid.Column="2"
                            Command="{Binding ClearAllCommand}"
                            Padding="6,4"
                            FontSize="12"
                            ToolTip.Tip="Clear all metrics">
                        <materialIcons:MaterialIcon Kind="DeleteOutline" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Empty state -->
            <StackPanel DockPanel.Dock="Top"
                        IsVisible="{Binding !HasRecords}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="24">
                <materialIcons:MaterialIcon Kind="ChartLine"
                                            Width="48"
                                            Height="48"
                                            Opacity="0.2"
                                            HorizontalAlignment="Center"/>
                <TextBlock Text="No queries executed yet"
                           Opacity="0.6"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- List -->
            <ListBox ItemsSource="{Binding RecentMetrics}"
                     SelectedItem="{Binding SelectedRecord}"
                     IsVisible="{Binding HasRecords}"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:QueryMetric}">
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:g}'}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                            <TextBlock Text="{Binding FormattedExecutionTime}"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DqlQuery}"
                                       MaxLines="2"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Opacity="0.7"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="1"
                      Background="{DynamicResource SukiLightBorderBrush}"
                      ResizeDirection="Columns"/>

        <!-- Right: detail panel -->
        <Panel Grid.Column="2">
            <!-- Empty state when no selection -->
            <StackPanel IsVisible="{Binding SelectedRecord, Converter={x:Static ObjectConverters.IsNull}}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="24">
                <materialIcons:MaterialIcon Kind="CursorPointer"
                                            Width="32"
                                            Height="32"
                                            Opacity="0.2"
                                            HorizontalAlignment="Center"/>
                <TextBlock Text="Select a query to view details"
                           Opacity="0.5"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Reuse inspector component -->
            <inspector:QueryMetricsView
                IsVisible="{Binding SelectedRecord, Converter={x:Static ObjectConverters.IsNotNull}}"/>
        </Panel>
    </Grid>
</UserControl>
