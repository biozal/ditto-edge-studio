<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:details="using:EdgeStudio.Views.StudioView.Details"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Details.QueryDocumentView"
             x:DataType="vm:QueryDocumentViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="*,4,300">
        <details:QueryEditorView Grid.Row="0"/>

        <GridSplitter Grid.Row="1"
                      Height="4"
                      MinHeight="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource SukiLowBrush}"
                      ResizeDirection="Rows"/>

        <details:QueryResultsView Grid.Row="2"/>
    </Grid>
</UserControl>
