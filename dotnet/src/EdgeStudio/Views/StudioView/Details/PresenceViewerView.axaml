<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:controls="using:EdgeStudio.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Details.PresenceViewerView"
             x:DataType="vm:PresenceViewerViewModel"
             x:CompileBindings="True">

    <Grid>
        <!-- Graph Canvas (fills entire area) -->
        <controls:PresenceGraphControl x:Name="GraphControl"
                                        Snapshot="{Binding Snapshot}"
                                        Positions="{Binding Positions}"
                                        ZoomLevel="{Binding ZoomLevel}"/>

        <!-- Empty state overlay -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding Snapshot, Converter={x:Static ObjectConverters.IsNull}}">
            <materialIcons:MaterialIcon Kind="GraphLine" Width="48" Height="48" Opacity="0.4"/>
            <TextBlock Text="Waiting for peer connections..."
                       FontSize="16"
                       Opacity="0.5"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Start sync to see the mesh network"
                       FontSize="14"
                       Opacity="0.3"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Controls overlay (bottom-right) -->
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,72"
                    Spacing="8">

            <!-- Direct Connected filter toggle -->
            <Border CornerRadius="6"
                    Padding="12,8"
                    Background="#CC000000">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Direct Only"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch IsChecked="{Binding ShowDirectOnly}"
                                  OnContent="" OffContent=""
                                  VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Zoom controls -->
            <Border CornerRadius="6"
                    Padding="8"
                    Background="#CC000000">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding ZoomOutCommand}"
                            Width="32" Height="32" Padding="0"
                            Background="Transparent">
                        <materialIcons:MaterialIcon Kind="Minus" Width="16" Height="16" Foreground="White"/>
                    </Button>
                    <TextBlock Text="{Binding ZoomPercentage}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               MinWidth="40"
                               TextAlignment="Center"/>
                    <Button Command="{Binding ZoomInCommand}"
                            Width="32" Height="32" Padding="0"
                            Background="Transparent">
                        <materialIcons:MaterialIcon Kind="Plus" Width="16" Height="16" Foreground="White"/>
                    </Button>
                    <Button Command="{Binding ResetZoomCommand}"
                            Width="32" Height="32" Padding="0"
                            Background="Transparent"
                            ToolTip.Tip="Reset View">
                        <materialIcons:MaterialIcon Kind="FitToPage" Width="16" Height="16" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
