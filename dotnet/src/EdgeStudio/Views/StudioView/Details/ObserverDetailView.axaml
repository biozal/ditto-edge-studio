<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Details.ObserverDetailView"
             x:DataType="vm:ObserversViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="*,Auto,*">

        <!-- Top Pane: Events List (50%) -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*,Auto">

            <!-- No Observer Selected -->
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding !HasSelectedObserver}"
                    Background="Transparent">
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Spacing="8">
                    <TextBlock Text="warning"
                              FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                              FontSize="48"
                              Opacity="0.3"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No Observer Selected"
                              FontSize="16"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an observer from the sidebar to view events."
                              FontSize="12"
                              Opacity="0.7"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- No Events -->
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding HasSelectedObserver}"
                    Background="Transparent">
                <Border IsVisible="{Binding !HasEvents}">
                    <StackPanel HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Spacing="8">
                        <TextBlock Text="notifications_none"
                                  FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                                  FontSize="48"
                                  Opacity="0.3"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="No Observer Events"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Activate an observer to see observable events."
                                  FontSize="12"
                                  Opacity="0.7"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Events Header -->
            <Border Grid.Row="0"
                    Padding="12,8"
                    BorderThickness="0,0,0,1"
                    IsVisible="{Binding HasEvents}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                              Text="{Binding DetailsTitle}"
                              FontSize="11"
                              FontWeight="Normal"
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                              FontSize="11"
                              Opacity="0.7"
                              VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} events">
                                <Binding Path="Events.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Events DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding PagedEvents}"
                      SelectedItem="{Binding SelectedEvent}"
                      IsVisible="{Binding HasEvents}"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"
                                       Binding="{Binding FormattedEventTime}"
                                       Width="150"
                                       MinWidth="100"/>
                    <DataGridTextColumn Header="Count"
                                       Binding="{Binding Data.Count}"
                                       Width="*"
                                       MinWidth="60"/>
                    <DataGridTextColumn Header="Inserted"
                                       Binding="{Binding InsertIndexes.Count}"
                                       Width="*"
                                       MinWidth="70"/>
                    <DataGridTextColumn Header="Updated"
                                       Binding="{Binding UpdatedIndexes.Count}"
                                       Width="*"
                                       MinWidth="70"/>
                    <DataGridTextColumn Header="Deleted"
                                       Binding="{Binding DeletedIndexes.Count}"
                                       Width="*"
                                       MinWidth="70"/>
                    <DataGridTextColumn Header="Moves"
                                       Binding="{Binding MovedIndexes.Count}"
                                       Width="*"
                                       MinWidth="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Event Pagination -->
            <Border Grid.Row="2" Padding="8,4" IsVisible="{Binding HasEvents}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,*">
                    <Button Grid.Column="1" Content="&lt;" Classes="Flat" Padding="8,2" FontSize="11"
                            Command="{Binding EventPreviousPageCommand}"/>
                    <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Page {0} of {1}">
                                <Binding Path="EventCurrentPage"/>
                                <Binding Path="EventPageCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="3" Content="&gt;" Classes="Flat" Padding="8,2" FontSize="11"
                            Command="{Binding EventNextPageCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Divider -->
        <GridSplitter Grid.Row="1"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- Bottom Pane: Event Detail (50%) -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto">

            <!-- No Event Selected -->
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding !HasSelectedEvent}"
                    Background="Transparent">
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Spacing="8">
                    <TextBlock Text="visibility_off"
                              FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                              FontSize="48"
                              Opacity="0.3"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No Event Selected"
                              FontSize="14"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an event from the list above to view its details."
                              FontSize="12"
                              Opacity="0.7"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Event Detail Header with View Mode Toggle and Filter -->
            <Border Grid.Row="0"
                    Padding="12,6"
                    BorderThickness="0,0,0,1"
                    IsVisible="{Binding HasSelectedEvent}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Left: Raw/Table Toggle -->
                    <StackPanel Grid.Column="0"
                               Orientation="Horizontal"
                               Spacing="2">
                        <RadioButton GroupName="DetailViewMode"
                                     Content="Raw"
                                     FontSize="10"
                                     Padding="8,4"
                                     IsChecked="{Binding IsRawMode, Mode=OneWay}"
                                     Command="{Binding SetDetailViewModeCommand}"
                                     CommandParameter="raw"/>
                        <RadioButton GroupName="DetailViewMode"
                                     Content="Table"
                                     FontSize="10"
                                     Padding="8,4"
                                     IsChecked="{Binding IsTableMode, Mode=OneWay}"
                                     Command="{Binding SetDetailViewModeCommand}"
                                     CommandParameter="table"/>
                    </StackPanel>

                    <!-- Right: Filter Label + Filter RadioButtons -->
                    <StackPanel Grid.Column="2"
                               Orientation="Horizontal"
                               Spacing="4">
                        <TextBlock Text="Filter:"
                                  FontSize="11"
                                  VerticalAlignment="Center"
                                  Opacity="0.7"/>
                        <RadioButton GroupName="EventFilter"
                                     Content="Items"
                                     FontSize="10"
                                     Padding="8,4"
                                     IsChecked="{Binding IsFilterItems, Mode=OneWay}"
                                     Command="{Binding SetEventFilterCommand}"
                                     CommandParameter="items"/>
                        <RadioButton GroupName="EventFilter"
                                     Content="Inserted"
                                     FontSize="10"
                                     Padding="8,4"
                                     IsChecked="{Binding IsFilterInserted, Mode=OneWay}"
                                     Command="{Binding SetEventFilterCommand}"
                                     CommandParameter="inserted"/>
                        <RadioButton GroupName="EventFilter"
                                     Content="Updated"
                                     FontSize="10"
                                     Padding="8,4"
                                     IsChecked="{Binding IsFilterUpdated, Mode=OneWay}"
                                     Command="{Binding SetEventFilterCommand}"
                                     CommandParameter="updated"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Raw Mode: Event Data List -->
            <ScrollViewer Grid.Row="1"
                         VerticalScrollBarVisibility="Auto"
                         IsVisible="{Binding IsRawMode}">
                <ItemsControl ItemsSource="{Binding PagedFilteredEventData}"
                             Margin="4"
                             IsVisible="{Binding HasSelectedEvent}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4"
                                    Margin="0,1"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding}"
                                          FontSize="11"
                                          FontFamily="Consolas"
                                          TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Table Mode: Placeholder -->
            <Border Grid.Row="1"
                    IsVisible="{Binding IsTableMode}"
                    Background="Transparent">
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Spacing="8"
                           IsVisible="{Binding HasSelectedEvent}">
                    <TextBlock Text="table_chart"
                              FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                              FontSize="48"
                              Opacity="0.3"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Table View Coming Soon"
                              FontSize="14"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="A data grid view of event data will be available in a future update."
                              FontSize="12"
                              Opacity="0.7"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Detail Pagination -->
            <Border Grid.Row="2" Padding="8,4" IsVisible="{Binding HasSelectedEvent}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,*">
                    <Button Grid.Column="1" Content="&lt;" Classes="Flat" Padding="8,2" FontSize="11"
                            Command="{Binding DetailPreviousPageCommand}"/>
                    <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Page {0} of {1}">
                                <Binding Path="DetailCurrentPage"/>
                                <Binding Path="DetailPageCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="3" Content="&gt;" Classes="Flat" Padding="8,2" FontSize="11"
                            Command="{Binding DetailNextPageCommand}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
