<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Details.ObserverDetailView"
             x:DataType="vm:ObserversViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="*,Auto,*">

        <!-- Top Pane: Events List (50%) -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*">

            <!-- No Observer Selected -->
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding !HasSelectedObserver}"
                    Background="Transparent">
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Spacing="8">
                    <TextBlock Text="warning"
                              FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                              FontSize="48"
                              Opacity="0.3"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No Observer Selected"
                              FontSize="16"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an observer from the sidebar to view events."
                              FontSize="12"
                              Opacity="0.7"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- No Events -->
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding HasSelectedObserver}"
                    Background="Transparent">
                <Border IsVisible="{Binding !HasEvents}">
                    <StackPanel HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Spacing="8">
                        <TextBlock Text="notifications_none"
                                  FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                                  FontSize="48"
                                  Opacity="0.3"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="No Observer Events"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Activate an observer to see observable events."
                                  FontSize="12"
                                  Opacity="0.7"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Events Header -->
            <Border Grid.Row="0"
                    Padding="12,8"
                    BorderThickness="0,0,0,1"
                    IsVisible="{Binding HasEvents}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                              Text="{Binding DetailsTitle}"
                              FontSize="11"
                              FontWeight="Normal"
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                              FontSize="11"
                              Opacity="0.7"
                              VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} events">
                                <Binding Path="Events.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Events DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Events}"
                      SelectedItem="{Binding SelectedEvent}"
                      IsVisible="{Binding HasEvents}"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"
                                       Binding="{Binding FormattedEventTime}"
                                       Width="150"
                                       MinWidth="100"/>
                    <DataGridTextColumn Header="Count"
                                       Binding="{Binding Data.Count}"
                                       Width="*"
                                       MinWidth="60"/>
                    <DataGridTextColumn Header="Inserted"
                                       Binding="{Binding InsertIndexes.Count}"
                                       Width="*"
                                       MinWidth="70"/>
                    <DataGridTextColumn Header="Updated"
                                       Binding="{Binding UpdatedIndexes.Count}"
                                       Width="*"
                                       MinWidth="70"/>
                    <DataGridTextColumn Header="Deleted"
                                       Binding="{Binding DeletedIndexes.Count}"
                                       Width="*"
                                       MinWidth="70"/>
                    <DataGridTextColumn Header="Moves"
                                       Binding="{Binding MovedIndexes.Count}"
                                       Width="*"
                                       MinWidth="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Divider -->
        <GridSplitter Grid.Row="1"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- Bottom Pane: Event Detail (50%) -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">

            <!-- No Event Selected -->
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding !HasSelectedEvent}"
                    Background="Transparent">
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Spacing="8">
                    <TextBlock Text="visibility_off"
                              FontFamily="avares://EdgeStudio/Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined"
                              FontSize="48"
                              Opacity="0.3"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No Event Selected"
                              FontSize="14"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an event from the list above to view its details."
                              FontSize="12"
                              Opacity="0.7"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Event Detail Header with Filter -->
            <Border Grid.Row="0"
                    Padding="12,6"
                    BorderThickness="0,0,0,1"
                    IsVisible="{Binding HasSelectedEvent}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                              Text="Event Data"
                              FontSize="11"
                              FontWeight="Normal"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                               Orientation="Horizontal"
                               Spacing="4">
                        <Button Content="All Items"
                                Classes="Flat"
                                FontSize="10"
                                Padding="8,4"
                                Command="{Binding SetEventFilterCommand}"
                                CommandParameter="items"/>
                        <Button Content="Inserted"
                                Classes="Flat"
                                FontSize="10"
                                Padding="8,4"
                                Command="{Binding SetEventFilterCommand}"
                                CommandParameter="inserted"/>
                        <Button Content="Updated"
                                Classes="Flat"
                                FontSize="10"
                                Padding="8,4"
                                Command="{Binding SetEventFilterCommand}"
                                CommandParameter="updated"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Event Data List -->
            <ScrollViewer Grid.Row="1"
                         VerticalScrollBarVisibility="Auto"
                         IsVisible="{Binding HasSelectedEvent}">
                <ItemsControl ItemsSource="{Binding FilteredEventData}"
                             Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4"
                                    Margin="0,1"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding}"
                                          FontSize="11"
                                          FontFamily="Consolas"
                                          TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
