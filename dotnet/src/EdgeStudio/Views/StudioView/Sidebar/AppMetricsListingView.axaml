<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Sidebar.AppMetricsListingView"
             x:DataType="vm:AppMetricsViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1">
            <TextBlock Text="App Metrics"
                       FontSize="18"
                       FontWeight="SemiBold"/>
        </Border>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Margin="24">
            <materialIcons:MaterialIcon Kind="ChartBox"
                                        Width="48"
                                        Height="48"
                                        Opacity="0.2"
                                        HorizontalAlignment="Center"/>
            <TextBlock Text="App Metrics"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Opacity="0.7"/>
            <TextBlock Text="Process, query, and storage metrics for this database session."
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Opacity="0.5"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
