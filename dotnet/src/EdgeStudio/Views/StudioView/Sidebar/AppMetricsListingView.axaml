<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.StudioView.Sidebar.AppMetricsListingView"
             x:DataType="vm:AppMetricsViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1">
            <TextBlock Text="App Metrics"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Border>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Margin="24">
            <TextBlock Text="App Metrics"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Opacity="0.7"/>
            <TextBlock Text="Coming soon"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Opacity="0.5"
                       FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</UserControl>
