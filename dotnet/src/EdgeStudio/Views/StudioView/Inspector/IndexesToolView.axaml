<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="EdgeStudio.Views.StudioView.Inspector.IndexesToolView"
             x:DataType="vm:IndexesToolViewModel">

    <ScrollViewer Margin="10">
        <StackPanel Spacing="10">
            <!-- Empty state with proper styling -->
            <suki:GlassCard CornerRadius="10" Padding="15">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <materialIcons:MaterialIcon Kind="InformationCircle"
                                               Foreground="{DynamicResource SukiPrimaryColor}"
                                               Width="16"
                                               Height="16"
                                               VerticalAlignment="Center"/>
                    <TextBlock Text="No indexes available"
                               Foreground="{DynamicResource SukiLowText}"
                               VerticalAlignment="Center"
                               FontStyle="Italic"/>
                </StackPanel>
            </suki:GlassCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>
