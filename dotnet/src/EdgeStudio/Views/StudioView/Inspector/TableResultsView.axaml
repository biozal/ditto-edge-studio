<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="300"
             x:Class="EdgeStudio.Views.StudioView.Inspector.TableResultsView"
             x:DataType="vm:TableResultsViewModel">

    <Grid Margin="4">
        <!-- Table Content -->
        <Border Background="{DynamicResource SukiBackground}"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <DataGrid x:Name="ResultsGrid"
                          ItemsSource="{Binding PagedTableData}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          GridLinesVisibility="All"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          Background="Transparent"
                          FontSize="14"
                          Foreground="{DynamicResource DittoCardText}"
                          DoubleTapped="OnRowDoubleTapped">
                    <DataGrid.Styles>
                        <Style Selector="DataGridColumnHeader">
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                        <Style Selector="DataGridCell">
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </DataGrid.Styles>
                </DataGrid>

                <!-- Empty state overlay when no data -->
                <suki:GlassCard CornerRadius="8"
                               Padding="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !TableData.Count}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <materialIcons:MaterialIcon Kind="TableOff"
                                                   Foreground="{DynamicResource SukiLowText}"
                                                   Width="20"
                                                   Height="20"
                                                   VerticalAlignment="Center"/>
                        <TextBlock Text="No results to display"
                                   Foreground="{DynamicResource SukiLowText}"
                                   VerticalAlignment="Center"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </suki:GlassCard>
            </Grid>
        </Border>
    </Grid>
</UserControl>
