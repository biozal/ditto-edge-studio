<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="60" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Navigation.NavigationBar"
             x:DataType="vm:NavigationViewModel"
             x:CompileBindings="True">

    <UserControl.Styles>
        <Style Selector="Button.NavButton">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="Button.NavButton:pointerover">
            <Setter Property="Background" Value="#1A3F51B5"/>
        </Style>

        <Style Selector="Button.NavButton.Selected">
            <Setter Property="Background" Value="#333F51B5"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding NavigationItems}"
                      Margin="0,8">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:NavigationItemViewModel">
                    <Button Classes="NavButton Flat"
                            Classes.Selected="{Binding IsSelected}"
                            Command="{Binding $parent[ItemsControl].DataContext.SelectNavigationItemCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding Tooltip}">
                        <avalonia:MaterialIcon Kind="{Binding IconKind}"
                                               Width="24"
                                               Height="24"/>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" Spacing="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </ScrollViewer>
</UserControl>