<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             xmlns:suki="using:SukiUI.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Workspaces.PeersListView"
             x:DataType="vm:PeersListViewModel"
             x:CompileBindings="True">

    <UserControl.Resources>
        <!-- Enum Equality Converter for CardType switching -->
        <x:Int32 x:Key="LocalCardType">0</x:Int32>
        <x:Int32 x:Key="RemoteCardType">1</x:Int32>
        <x:Int32 x:Key="ServerCardType">2</x:Int32>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Padding="8" IsVisible="{Binding HasPeers}">
            <TextBlock Text="Connected Peers"
                      FontSize="16"
                      FontWeight="SemiBold"/>
        </Border>

        <!-- Remote/Server Peer Cards (Scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="8">

                <!-- Loading State -->
                <Border IsVisible="{Binding IsLoading}">
                    <StackPanel HorizontalAlignment="Center" Spacing="16">
                        <ProgressBar IsIndeterminate="True" Width="32" Height="32"/>
                        <TextBlock Text="Loading peers..." FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Peer Cards (Grid View with WrapPanel) -->
                <ItemsControl ItemsSource="{Binding PeerCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:ObservablePeerCardInfo">
                            <suki:GlassCard Margin="0,0,12,12" Width="400">
                                <Grid Margin="16">
                                    <!-- Server Card -->
                                    <StackPanel IsVisible="{Binding CardType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:PeerCardType.Server}}">
                                        <TextBlock Text="Server" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Id}" FontSize="11" FontFamily="Consolas" Opacity="0.7" TextWrapping="Wrap"/>
                                        <Border Height="1" Background="{DynamicResource SukiBorderBrush}" Margin="0,8"/>
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <materialIcons:MaterialIcon Kind="CheckCircle" Width="14" Height="14"/>
                                                <TextBlock Text="{Binding CommitId, StringFormat='Commit: {0}'}" FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <materialIcons:MaterialIcon Kind="Schedule" Width="14" Height="14"/>
                                                <TextBlock Text="{Binding LastUpdatedFormatted}" FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="8" Height="8" Fill="{DynamicResource SukiPrimaryColor}" IsVisible="{Binding IsConnected}" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Opacity="0.4" IsVisible="{Binding !IsConnected}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ConnectionStatus}" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Remote Card -->
                                    <StackPanel IsVisible="{Binding CardType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:PeerCardType.Remote}}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Id}" FontSize="11" FontFamily="Consolas" Opacity="0.7" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                                                <Ellipse Width="8" Height="8" Fill="{DynamicResource SukiPrimaryColor}" IsVisible="{Binding IsConnected}"/>
                                                <Ellipse Width="8" Height="8" Opacity="0.4" IsVisible="{Binding !IsConnected}"/>
                                                <TextBlock Text="{Binding ConnectionStatus}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- OS Info with Icon -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0" IsVisible="{Binding OperatingSystem, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <materialIcons:MaterialIcon Kind="{Binding OsIconKind}" Width="16" Height="16"/>
                                            <TextBlock Text="{Binding OperatingSystem}" FontSize="11" Opacity="0.8"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource SukiBorderBrush}" Margin="0,8"/>

                                        <!-- Active Connections -->
                                        <ItemsControl ItemsSource="{Binding ActiveConnections}" IsVisible="{Binding ActiveConnections, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:PeerConnectionInfo">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                                        <materialIcons:MaterialIcon Kind="{Binding IconKind}" Width="14" Height="14"/>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.8"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Spacing="4" Margin="0,4,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <materialIcons:MaterialIcon Kind="CheckCircle" Width="14" Height="14"/>
                                                <TextBlock Text="{Binding CommitId, StringFormat='Commit: {0}'}" FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <materialIcons:MaterialIcon Kind="Schedule" Width="14" Height="14"/>
                                                <TextBlock Text="{Binding LastUpdatedFormatted}" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Local Card -->
                                    <StackPanel IsVisible="{Binding CardType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:PeerCardType.Local}}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <materialIcons:MaterialIcon Kind="Computer"
                                                                               Width="14" Height="14"
                                                                               Foreground="{DynamicResource SukiPrimaryColor}"/>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock Text="Local Peer" FontSize="11" Opacity="0.7"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Height="1" Background="{DynamicResource SukiBorderBrush}" Margin="0,8"/>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding SdkPlatform}" FontSize="11" IsVisible="{Binding SdkPlatform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding SdkVersion, StringFormat=SDK {0}}" FontSize="11" Opacity="0.8" IsVisible="{Binding SdkVersion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </suki:GlassCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <Border IsVisible="{Binding ShowEmptyState}">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="No Peers Found" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="No connected peers at this time" FontSize="12" Opacity="0.7"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
