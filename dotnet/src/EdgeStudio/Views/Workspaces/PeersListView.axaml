<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:models="using:EdgeStudio.Shared.Models"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Workspaces.PeersListView"
             x:DataType="vm:PeersListViewModel"
             x:CompileBindings="True">

   <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Padding="8" IsVisible="{Binding HasPeers}">
            <TextBlock Text="Connected Peers"
                      FontSize="16"
                      FontWeight="SemiBold"/>
        </Border>

        <!-- Peer Cards (Scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="8">

                <!-- Loading State -->
                <Border IsVisible="{Binding IsLoading}">
                    <StackPanel HorizontalAlignment="Center" Spacing="16">
                        <ProgressBar IsIndeterminate="True" Width="32" Height="32"/>
                        <TextBlock Text="Loading peers..." FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Peer Cards (WrapPanel grid) -->
                <ItemsControl ItemsSource="{Binding PeerCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:ObservablePeerCardInfo">
                            <Panel Margin="0,0,12,12" Width="440">

                                <!-- ================================================
                                     REMOTE / SERVER CARD — colour-coded gradient
                                     ================================================ -->
                                <Border CornerRadius="12"
                                        MinHeight="240"
                                        Padding="20"
                                        BoxShadow="0 4 16 0 #50000000"
                                        IsVisible="{Binding IsRemoteOrServer}"
                                        Background="{Binding GradientBrush}">
                                    <StackPanel>

                                        <!-- Header row: name/OS/key on left, status dot on right -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="White"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4"
                                                            IsVisible="{Binding OperatingSystem, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                    <materialIcons:MaterialIcon Kind="{Binding OsIconKind}"
                                                                               Width="12" Height="12"
                                                                               Foreground="White" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding OperatingSystem}"
                                                               FontSize="11" Foreground="White" Opacity="0.8"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Id}"
                                                           FontSize="10" FontFamily="Consolas"
                                                           Foreground="White" Opacity="0.8"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- Status dot + text -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal" Spacing="4"
                                                        VerticalAlignment="Top">
                                                <Ellipse Width="8" Height="8"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding StatusDotBrush}"/>
                                                <TextBlock Text="{Binding SyncSessionStatus}"
                                                           FontSize="11" Foreground="White"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Divider -->
                                        <Border Height="1" Background="#40FFFFFF" Margin="0,8"/>

                                        <!-- SDK Version row -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6"
                                                    IsVisible="{Binding DittoSdkVersion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <materialIcons:MaterialIcon Kind="Memory"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding DittoSdkVersion, StringFormat='Ditto SDK: {0}'}"
                                                       FontSize="12" Foreground="White" Opacity="0.8"/>
                                        </StackPanel>

                                        <!-- Ditto Address row -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6"
                                                    IsVisible="{Binding DittoAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <materialIcons:MaterialIcon Kind="Link"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding DittoAddress}"
                                                       FontSize="12" FontFamily="Consolas"
                                                       Foreground="White" Opacity="0.8"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Identity Metadata expander -->
                                        <Expander Margin="0,4,0,0" Foreground="White"
                                                  IsVisible="{Binding IdentityMetadata, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <materialIcons:MaterialIcon Kind="AccountBox"
                                                                                Width="14" Height="14"
                                                                                Foreground="White"/>
                                                    <TextBlock Text="Identity Metadata"
                                                               FontSize="12" Foreground="White"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ScrollViewer MaxHeight="150">
                                                <TextBlock Text="{Binding IdentityMetadata}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="White" Opacity="0.8"
                                                           TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                        </Expander>

                                        <!-- Peer Metadata expander -->
                                        <Expander Margin="0,4,0,0" Foreground="White"
                                                  IsVisible="{Binding PeerMetadata, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <materialIcons:MaterialIcon Kind="Info"
                                                                                Width="14" Height="14"
                                                                                Foreground="White"/>
                                                    <TextBlock Text="Peer Metadata"
                                                               FontSize="12" Foreground="White"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ScrollViewer MaxHeight="150">
                                                <TextBlock Text="{Binding PeerMetadata}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="White" Opacity="0.8"
                                                           TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                        </Expander>

                                        <!-- Active Connections section -->
                                        <StackPanel Margin="0,4,0,0"
                                                    IsVisible="{Binding ActiveConnections, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <TextBlock Text="{Binding ActiveConnectionsCountText}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="White" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding ActiveConnections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="models:PeerConnectionInfo">
                                                        <Border Background="#1FFFFFFF"
                                                                BorderBrush="#33FFFFFF"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10,6"
                                                                Margin="0,0,0,6">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <materialIcons:MaterialIcon Kind="{Binding IconKind}"
                                                                                               Width="12" Height="12"
                                                                                               Foreground="White"/>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontSize="11" Foreground="White"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding FormattedDistance, StringFormat='Distance: {0}'}"
                                                                           FontSize="10" Foreground="White" Opacity="0.8"
                                                                           IsVisible="{Binding FormattedDistance, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Commit ID row -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0"
                                                    IsVisible="{Binding CommitId, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <materialIcons:MaterialIcon Kind="CheckCircle"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding CommitId, StringFormat='Synced to commit: {0}'}"
                                                       FontSize="12" Foreground="White" Opacity="0.8"/>
                                        </StackPanel>

                                        <!-- Last Updated row -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                            <materialIcons:MaterialIcon Kind="Schedule"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding LastUpdatedFormatted}"
                                                       FontSize="12" Foreground="White" Opacity="0.8"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>

                                <!-- ================================================
                                     LOCAL PEER CARD — neutral theme-adaptive style
                                     ================================================ -->
                                <Border CornerRadius="12"
                                        MinHeight="180"
                                        Padding="20"
                                        BoxShadow="0 4 16 0 #50000000"
                                        IsVisible="{Binding IsLocalPeer}"
                                        Background="{DynamicResource DittoCardSurface}">
                                    <StackPanel>

                                        <!-- Header: hub icon + "Local Peer" -->
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <materialIcons:MaterialIcon Kind="Hub"
                                                                        Width="18" Height="18"
                                                                        Foreground="{DynamicResource SukiPrimaryColor}"/>
                                            <TextBlock Text="Local Peer"
                                                       FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Divider -->
                                        <Border Height="1"
                                                Background="{DynamicResource SukiBorderBrush}"
                                                Margin="0,8" Opacity="0.2"/>

                                        <!-- Info rows: label / value pairs -->
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                                              Margin="0,4">
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="Device Name" FontSize="11" Opacity="0.7"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding DeviceName}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="SDK Language" FontSize="11" Opacity="0.7"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding SdkLanguage}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       Margin="0,6,0,0"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                       Text="SDK Platform" FontSize="11" Opacity="0.7"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1"
                                                       Text="{Binding SdkPlatform}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       Margin="0,6,0,0"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0"
                                                       Text="SDK Version" FontSize="11" Opacity="0.7"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1"
                                                       Text="{Binding SdkVersion}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       Margin="0,6,0,0"/>
                                        </Grid>

                                    </StackPanel>
                                </Border>

                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <Border IsVisible="{Binding ShowEmptyState}">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="No Peers Found" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="No connected peers at this time" FontSize="12" Opacity="0.7"/>
                    </StackPanel>
                </Border>

                <!-- ================================================
                     LOCAL NETWORK ADAPTERS SECTION
                     ================================================ -->
                <StackPanel IsVisible="{Binding HasNetworkAdapters}" Spacing="0">

                    <!-- Section divider: line — "Local Network" — line -->
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,8,0,12">
                        <Border Grid.Column="0" Height="1"
                                Background="{DynamicResource SukiBorderBrush}"
                                Opacity="0.3"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="Local Network"
                                   FontSize="12" FontWeight="SemiBold"
                                   Opacity="0.6"
                                   Margin="12,0"/>
                        <Border Grid.Column="2" Height="1"
                                Background="{DynamicResource SukiBorderBrush}"
                                Opacity="0.3"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Network adapter cards -->
                    <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:NetworkAdapterInfo">
                                <Border CornerRadius="12"
                                        Width="440"
                                        Padding="20"
                                        BoxShadow="0 4 16 0 #50000000"
                                        Margin="0,0,12,12"
                                        Background="{Binding GradientBrush}">
                                    <StackPanel>

                                        <!-- Header: icon + kind + name + active dot -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                <materialIcons:MaterialIcon Kind="{Binding IconKind}"
                                                                            Width="18" Height="18"
                                                                            Foreground="White"/>
                                                <StackPanel Spacing="1">
                                                    <TextBlock Text="{Binding KindLabel}"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11" Foreground="White" Opacity="0.8"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Active / inactive indicator -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal" Spacing="4"
                                                        VerticalAlignment="Top">
                                                <Ellipse Width="8" Height="8"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding ActiveDotBrush}"/>
                                                <TextBlock Text="{Binding ActiveLabel}"
                                                           FontSize="11" Foreground="White"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Divider -->
                                        <Border Height="1" Background="#40FFFFFF" Margin="0,8"/>

                                        <!-- IPv4 addresses -->
                                        <ItemsControl ItemsSource="{Binding IPv4Addresses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="x:String">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                                                        <materialIcons:MaterialIcon Kind="Numeric4Circle"
                                                                                    Width="14" Height="14"
                                                                                    Foreground="White" Opacity="0.8"/>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="12" FontFamily="Consolas"
                                                                   Foreground="White" Opacity="0.8"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- IPv6 addresses -->
                                        <ItemsControl ItemsSource="{Binding IPv6Addresses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="x:String">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                                                        <materialIcons:MaterialIcon Kind="Numeric6Circle"
                                                                                    Width="14" Height="14"
                                                                                    Foreground="White" Opacity="0.8"/>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="11" FontFamily="Consolas"
                                                                   Foreground="White" Opacity="0.7"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Gateway -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6"
                                                    IsVisible="{Binding GatewayAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <materialIcons:MaterialIcon Kind="Router"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding GatewayAddress, StringFormat='Gateway: {0}'}"
                                                       FontSize="12" Foreground="White" Opacity="0.8"/>
                                        </StackPanel>

                                        <!-- MAC Address -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6"
                                                    IsVisible="{Binding MacAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <materialIcons:MaterialIcon Kind="Chip"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding MacAddress}"
                                                       FontSize="12" FontFamily="Consolas"
                                                       Foreground="White" Opacity="0.8"/>
                                        </StackPanel>

                                        <!-- Link Speed -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,0"
                                                    IsVisible="{Binding LinkSpeedBps, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <materialIcons:MaterialIcon Kind="Speedometer"
                                                                        Width="14" Height="14"
                                                                        Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text="{Binding LinkSpeedFormatted}"
                                                       FontSize="12" Foreground="White" Opacity="0.8"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
