<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Workspaces.QueryListingView"
             x:DataType="vm:QueryViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,12,*,Auto">
        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Collections"
                   FontSize="16"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="12,8"/>

        <!-- Collections List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12,0">
            <ItemsControl ItemsSource="{Binding Collections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <suki:GlassCard IsInteractive="True"
                                        Margin="0,0,0,8"
                                        Cursor="Hand">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{Binding DocumentCount, StringFormat='{}{0} documents'}"
                                           FontSize="12"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </suki:GlassCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding !HasCollections}">
            <materialIcons:MaterialIcon Kind="VectorArrangeAbove"
                                        Width="48"
                                        Height="48"
                                        Opacity="0.3"
                                        HorizontalAlignment="Center"/>
            <TextBlock Text="No collections found"
                       FontSize="13"
                       Opacity="0.6"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Loading Indicator -->
        <Border Grid.Row="2"
                IsVisible="{Binding IsLoading}">
            <ProgressBar IsIndeterminate="True"
                         Width="100"
                         Height="100"
                         Classes="circular"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Text="{Binding Collections.Count, StringFormat='{}{0} collections'}"
                   FontSize="11"
                   Opacity="0.5"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,12"/>
    </Grid>
</UserControl>
