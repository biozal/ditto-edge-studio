<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:workspaces="using:EdgeStudio.Views.Workspaces"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="EdgeStudio.Views.Workspaces.QueryView"
             x:DataType="vm:QueryViewModel"
             x:CompileBindings="True">

    <UserControl.Styles>
        <!-- Tab Control Styling to match SukiUI -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="#1e2837"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Tab Item Styling - Inactive tabs -->
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2,2,0"/>
            <Setter Property="Background" Value="#252d3d"/>
            <Setter Property="Foreground" Value="#d4d4d4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Tab Item Styling - Active/Selected tab -->
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#1e2837"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Tab Item Hover state -->
        <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2a3241"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Tab Control with SukiUI styling -->
        <TabControl ItemsSource="{Binding QueryDocuments}"
                    SelectedItem="{Binding CurrentQueryDocument}">

            <TabControl.ItemTemplate>
                <DataTemplate DataType="vm:QueryDocumentViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Title}"
                                   VerticalAlignment="Center"/>
                        <Button Classes="Icon"
                                Width="16"
                                Height="16"
                                Padding="0"
                                Background="Transparent"
                                Command="{Binding $parent[UserControl].((vm:QueryViewModel)DataContext).CloseQueryCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Close query"
                                Foreground="{Binding $parent[TabItem].Foreground}">
                            <materialIcons:MaterialIcon Kind="Close" Width="11" Height="11"/>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="vm:QueryDocumentViewModel">
                    <workspaces:QueryDocumentView/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- + Button positioned at the end of tab headers (inline) -->
        <Button Command="{Binding NewQueryCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Margin="0,6,6,0"
                Width="28"
                Height="28"
                Padding="4"
                ToolTip.Tip="New query"
                Foreground="#d4d4d4">
            <materialIcons:MaterialIcon Kind="Plus" Width="18" Height="18"/>
            <Button.Styles>
                <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="#2a3241"/>
                </Style>
            </Button.Styles>
        </Button>
    </Grid>
</UserControl>