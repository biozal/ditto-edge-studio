<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="EdgeStudio.Views.Workspaces.SubscriptionSettingsView"
             x:DataType="vm:SubscriptionSettingsViewModel">

    <StackPanel Spacing="16" Margin="20,16,20,8">

        <!-- Warning Banner -->
        <Border Background="#33FF6D00"
                BorderBrush="#FF6D00"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid ColumnDefinitions="Auto,*">
                <avalonia:MaterialIcon Grid.Column="0"
                                      Kind="Warning"
                                      Width="18"
                                      Height="18"
                                      Foreground="#FF6D00"
                                      VerticalAlignment="Top"
                                      Margin="0,1,8,0"/>
                <TextBlock Grid.Column="1"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="#FF6D00"
                           Text="Changing transport settings will stop sync, update the configuration, and restart sync. This will disconnect all peers and reconnect only using the enabled transports."/>
            </Grid>
        </Border>

        <!-- Peer-to-Peer Transports -->
        <StackPanel Spacing="8">
            <TextBlock Text="Peer-to-Peer Transports"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Opacity="0.7"
                       Margin="0,0,0,2"/>

            <!-- Bluetooth LE -->
            <Border Padding="12,10" CornerRadius="6" Background="#10808080">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="10" Height="10"
                            CornerRadius="5"
                            Background="#0066CC"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Bluetooth LE" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Allow peer-to-peer sync via Bluetooth Low Energy"
                                   FontSize="11"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding IsBluetoothEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Local Area Network -->
            <Border Padding="12,10" CornerRadius="6" Background="#10808080">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="10" Height="10"
                            CornerRadius="5"
                            Background="#00AA44"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Local Area Network" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Sync with peers on the same local network"
                                   FontSize="11"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding IsLanEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Apple Wireless Direct Link (macOS only) -->
            <Border Padding="12,10"
                    CornerRadius="6"
                    Background="#10808080"
                    IsVisible="{Binding ShowAwdl}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="10" Height="10"
                            CornerRadius="5"
                            Background="#8844DD"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Apple Wireless Direct Link" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="High-speed sync with Apple devices only"
                                   FontSize="11"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding IsAwdlEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- WiFiAware (Windows/Android only) -->
            <Border Padding="12,10"
                    CornerRadius="6"
                    Background="#10808080"
                    IsVisible="{Binding ShowWifiAware}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="10" Height="10"
                            CornerRadius="5"
                            Background="#FF6D00"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="WiFi Aware" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Peer-to-peer sync via WiFi Aware protocol"
                                   FontSize="11"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding IsWifiAwareEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Cloud Sync -->
        <StackPanel Spacing="8">
            <TextBlock Text="Cloud Sync"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Opacity="0.7"
                       Margin="0,0,0,2"/>

            <!-- WebSocket Sync -->
            <Border Padding="12,10" CornerRadius="6" Background="#10808080">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="10" Height="10"
                            CornerRadius="5"
                            Background="#00BBDD"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="WebSocket Sync" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Allow syncing to Ditto cloud server"
                                   FontSize="11"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding IsWebSocketEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

    </StackPanel>
</UserControl>
