<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Workspaces.AppMetricsDetailView"
             x:DataType="vm:AppMetricsViewModel"
             x:CompileBindings="True">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="App Metrics"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Opacity="0.6"/>
            <TextBlock Text="Application metrics and diagnostics coming soon."
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Opacity="0.5"
                       FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</UserControl>
