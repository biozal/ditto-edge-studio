<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:navigation="using:EdgeStudio.Views.Navigation"
             xmlns:workspaces="using:EdgeStudio.Views.Workspaces"
             xmlns:tools="using:EdgeStudio.Views.Tools"
             xmlns:inspector="using:EdgeStudio.Views.Inspector"
             xmlns:controls="using:EdgeStudio.Views.Controls"
             xmlns:suki="using:SukiUI.Controls"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="EdgeStudio.Views.EdgeStudioView"
             x:DataType="vm:EdgeStudioViewModel"
             x:CompileBindings="True">

    <UserControl.Styles>
        <!-- Sync button icon - enabled state (green) -->
        <Style Selector="Button.SyncButton.SyncEnabled > avalonia|MaterialIcon">
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>

        <!-- Sync button icon - disabled state (red) -->
        <Style Selector="Button.SyncButton.SyncDisabled > avalonia|MaterialIcon">
            <Setter Property="Foreground" Value="#F44336"/>
        </Style>

        <!-- Sync button icon - hover states (brighter) -->
        <Style Selector="Button.SyncButton.SyncEnabled:pointerover > avalonia|MaterialIcon">
            <Setter Property="Foreground" Value="#66BB6A"/>
        </Style>

        <Style Selector="Button.SyncButton.SyncDisabled:pointerover > avalonia|MaterialIcon">
            <Setter Property="Foreground" Value="#EF5350"/>
        </Style>

        <!-- Disabled state -->
        <Style Selector="Button.SyncButton:disabled > avalonia|MaterialIcon">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
    </UserControl.Styles>

    <Design.DataContext>
        <vm:EdgeStudioViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar with Database Name -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                Padding="16,20,16,12">
            <TextBlock Text="{Binding DatabaseName}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Button Container in Top Right -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,8,16,6"
                    Spacing="8">

            <!-- Inspector Toggle Button -->
            <Button Command="{Binding ToggleInspectorCommand}"
                    Classes="Rounded"
                    Background="{DynamicResource DittoCardSurface}"
                    Foreground="{DynamicResource DittoCardText}"
                    Width="36"
                    Height="36"
                    Padding="0"
                    ToolTip.Tip="Toggle Inspector">
                <avalonia:MaterialIcon Kind="DockRight" Width="20" Height="20"/>
            </Button>

            <!-- Sync Toggle Button -->
            <Button Command="{Binding ToggleSyncCommand}"
                    Classes="Rounded SyncButton"
                    Classes.SyncEnabled="{Binding IsSyncEnabled}"
                    Classes.SyncDisabled="{Binding !IsSyncEnabled}"
                    Background="{DynamicResource DittoCardSurface}"
                    Foreground="{DynamicResource DittoCardText}"
                    Width="36"
                    Height="36"
                    Padding="0"
                    IsEnabled="{Binding IsSyncButtonEnabled}"
                    ToolTip.Tip="{Binding SyncButtonTooltip}">
                <avalonia:MaterialIcon Kind="Sync" Width="20" Height="20"/>
            </Button>

            <!-- Close Button -->
            <Button Command="{Binding CloseDatabaseCommand}"
                    Classes="Rounded"
                    Background="{DynamicResource DittoDanger}"
                    Foreground="White"
                    Width="36"
                    Height="36"
                    Padding="0"
                    ToolTip.Tip="Close Database">
                <avalonia:MaterialIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Nav Bar -->
                <ColumnDefinition Width="48" MinWidth="48" MaxWidth="60"/>
                <!-- First Splitter -->
                <ColumnDefinition Width="Auto"/>
                <!-- Collections Panel (collapsed when IsListingPanelVisible=false) -->
                <ColumnDefinition Width="Auto"/>
                <!-- Second Splitter -->
                <ColumnDefinition Width="Auto"/>
                <!-- Main Content Area (Detail Views) -->
                <ColumnDefinition Width="*" MinWidth="400"/>
                <!-- Inspector Splitter (visible only when inspector is open) -->
                <ColumnDefinition Width="Auto"/>
                <!-- Inspector Panel (collapses when IsVisible=false) -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon Navigation Bar -->
            <Border Grid.Column="0" Background="#10000000">
                <navigation:NavigationBar DataContext="{Binding NavigationViewModel}"/>
            </Border>

            <!-- First Splitter (hidden when listing panel is hidden) -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          IsVisible="{Binding IsListingPanelVisible}">
                <GridSplitter.Styles>
                    <Style Selector="GridSplitter:pointerover">
                        <Setter Property="Background" Value="#20FFFFFF"/>
                    </Style>
                    <Style Selector="GridSplitter:pressed">
                        <Setter Property="Background" Value="#007ACC"/>
                    </Style>
                </GridSplitter.Styles>
            </GridSplitter>

            <!-- Collections/Listing Panel (hidden for Logging nav) -->
            <Border Grid.Column="2"
                    Width="250" MinWidth="200" MaxWidth="500"
                    Background="#05000000"
                    IsVisible="{Binding IsListingPanelVisible}">
                <ContentControl Content="{Binding CurrentListingViewModel}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:SubscriptionViewModel}">
                            <workspaces:SubscriptionListingView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:QueryViewModel}">
                            <workspaces:QueryListingView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ObserversViewModel}">
                            <workspaces:ObserverListingView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:LoggingViewModel}">
                            <workspaces:LoggingListingView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:AppMetricsViewModel}">
                            <workspaces:AppMetricsListingView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:QueryMetricsViewModel}">
                            <workspaces:QueryMetricsListingView/>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>

            <!-- Second Splitter -->
            <GridSplitter Grid.Column="3"
                          Width="5"
                          Background="Transparent"
                          ResizeDirection="Columns">
                <GridSplitter.Styles>
                    <Style Selector="GridSplitter:pointerover">
                        <Setter Property="Background" Value="#20FFFFFF"/>
                    </Style>
                    <Style Selector="GridSplitter:pressed">
                        <Setter Property="Background" Value="#007ACC"/>
                    </Style>
                </GridSplitter.Styles>
            </GridSplitter>

            <!-- Main Content Area - Detail Views -->
            <Grid Grid.Column="4">
              <Border Background="#05000000">
                <ContentControl Content="{Binding CurrentDetailViewModel}">
                    <ContentControl.DataTemplates>

                        <!-- Query View - Special Layout with Query Editor + Results + Tools -->
                        <DataTemplate DataType="{x:Type vm:QueryViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Query Editor + Results Area -->
                                    <ColumnDefinition Width="*" MinWidth="500"/>
                                    <!-- Splitter -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Tools Panel -->
                                    <ColumnDefinition Width="300" MinWidth="200" MaxWidth="600"/>
                                </Grid.ColumnDefinitions>

                                <!-- Query Editor + Results Panel -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <!-- Query Editor Area -->
                                        <RowDefinition Height="*" MinHeight="300"/>
                                        <!-- Horizontal Splitter -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Results Area -->
                                        <RowDefinition Height="350" MinHeight="200"/>
                                    </Grid.RowDefinitions>

                                    <!-- Query Editor -->
                                    <Border Grid.Row="0" Background="{DynamicResource SukiBackground}">
                                        <workspaces:QueryView/>
                                    </Border>

                                    <!-- Horizontal Splitter between Query and Results -->
                                    <GridSplitter Grid.Row="1"
                                                  Height="5"
                                                  Background="Transparent"
                                                  ResizeDirection="Rows"
                                                  HorizontalAlignment="Stretch">
                                        <GridSplitter.Styles>
                                            <Style Selector="GridSplitter:pointerover">
                                                <Setter Property="Background" Value="#20FFFFFF"/>
                                            </Style>
                                            <Style Selector="GridSplitter:pressed">
                                                <Setter Property="Background" Value="#007ACC"/>
                                            </Style>
                                        </GridSplitter.Styles>
                                    </GridSplitter>

                                    <!-- Results Panel with Tabs -->
                                    <Border Grid.Row="2" Background="#1e2837">
                                        <TabControl Background="#1e2837">
                                            <TabControl.Styles>
                                                <Style Selector="TabItem">
                                                    <Setter Property="FontSize" Value="13"/>
                                                    <Setter Property="Padding" Value="12,8"/>
                                                    <Setter Property="Background" Value="#252d3d"/>
                                                    <Setter Property="Foreground" Value="#d4d4d4"/>
                                                </Style>
                                                <Style Selector="TabItem:selected">
                                                    <Setter Property="Background" Value="#1e2837"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </TabControl.Styles>
                                            <TabItem Header="JSON">
                                                <tools:JsonResultsView DataContext="{Binding JsonResults}"/>
                                            </TabItem>
                                            <TabItem Header="Table">
                                                <tools:TableResultsView DataContext="{Binding TableResults}"/>
                                            </TabItem>
                                            <TabItem Header="Explain">
                                                <tools:ExplainResultsView DataContext="{Binding ExplainResults}"/>
                                            </TabItem>
                                        </TabControl>
                                    </Border>
                                </Grid>

                                <!-- Vertical Splitter -->
                                <GridSplitter Grid.Column="1"
                                              Width="5"
                                              Background="Transparent"
                                              ResizeDirection="Columns">
                                    <GridSplitter.Styles>
                                        <Style Selector="GridSplitter:pointerover">
                                            <Setter Property="Background" Value="#20FFFFFF"/>
                                        </Style>
                                        <Style Selector="GridSplitter:pressed">
                                            <Setter Property="Background" Value="#007ACC"/>
                                        </Style>
                                    </GridSplitter.Styles>
                                </GridSplitter>

                                <!-- Tools Panel with Tabs -->
                                <Border Grid.Column="2" Background="#1e2837">
                                    <TabControl Background="#1e2837">
                                        <TabControl.Styles>
                                            <Style Selector="TabItem">
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="Background" Value="#252d3d"/>
                                                <Setter Property="Foreground" Value="#d4d4d4"/>
                                            </Style>
                                            <Style Selector="TabItem:selected">
                                                <Setter Property="Background" Value="#1e2837"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Style>
                                        </TabControl.Styles>
                                        <TabItem Header="Indexes">
                                            <TextBlock Text="Indexes view coming soon..."
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.7"/>
                                        </TabItem>
                                        <TabItem Header="History">
                                            <TextBlock Text="History view coming soon..."
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.7"/>
                                        </TabItem>
                                        <TabItem Header="Favorites">
                                            <TextBlock Text="Favorites view coming soon..."
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.7"/>
                                        </TabItem>
                                    </TabControl>
                                </Border>
                            </Grid>
                        </DataTemplate>

                        <!-- Subscription Details View -->
                        <DataTemplate DataType="{x:Type vm:SubscriptionDetailsViewModel}">
                            <workspaces:SubscriptionDetailsView/>
                        </DataTemplate>

                        <!-- Observers View -->
                        <DataTemplate DataType="{x:Type vm:ObserversViewModel}">
                            <workspaces:ObserverDetailView/>
                        </DataTemplate>

                        <!-- Logging View -->
                        <DataTemplate DataType="{x:Type vm:LoggingViewModel}">
                            <workspaces:LoggingDetailView/>
                        </DataTemplate>

                        <!-- App Metrics View -->
                        <DataTemplate DataType="{x:Type vm:AppMetricsViewModel}">
                            <workspaces:AppMetricsDetailView/>
                        </DataTemplate>

                        <!-- Query Metrics View -->
                        <DataTemplate DataType="{x:Type vm:QueryMetricsViewModel}">
                            <workspaces:QueryMetricsDetailView/>
                        </DataTemplate>

                    </ContentControl.DataTemplates>
                </ContentControl>
              </Border>

              <!-- Floating DetailBottomBar overlay — inherits EdgeStudioViewModel DataContext -->
              <controls:DetailBottomBar VerticalAlignment="Bottom"/>

            </Grid>

            <!-- Inspector Splitter (visible when IsInspectorVisible=true) -->
            <GridSplitter Grid.Column="5"
                          Width="5"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          IsVisible="{Binding IsInspectorVisible}">
                <GridSplitter.Styles>
                    <Style Selector="GridSplitter:pointerover">
                        <Setter Property="Background" Value="#20FFFFFF"/>
                    </Style>
                    <Style Selector="GridSplitter:pressed">
                        <Setter Property="Background" Value="#007ACC"/>
                    </Style>
                </GridSplitter.Styles>
            </GridSplitter>

            <!-- Inspector Panel -->
            <Border Grid.Column="6"
                    Width="280"
                    MinWidth="200"
                    MaxWidth="500"
                    IsVisible="{Binding IsInspectorVisible}">
                <inspector:InspectorView/>
            </Border>

        </Grid>
    </Grid>
</UserControl>
