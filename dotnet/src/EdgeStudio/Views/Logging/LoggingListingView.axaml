<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             x:Class="EdgeStudio.Views.Logging.LoggingListingView"
             x:DataType="vm:LoggingViewModel"
             x:CompileBindings="True">

    <StackPanel>
        <!-- Header -->
        <Border Padding="16,14" BorderThickness="0,0,0,1">
            <TextBlock Text="Logging"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Active source indicator + entry count -->
        <Border Padding="16,10">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalEntryCount, StringFormat='{}{0} entries'}"
                               FontSize="14"
                               Opacity="0.65"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
