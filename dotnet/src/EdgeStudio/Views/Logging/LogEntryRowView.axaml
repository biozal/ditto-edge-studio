<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:logging="using:EdgeStudio.Models.Logging"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="52"
             x:Class="EdgeStudio.Views.Logging.LogEntryRowView"
             x:DataType="logging:LogEntry"
             x:CompileBindings="False">

    <!-- Use non-compiled bindings so hex-string→Brush conversion works for level colors -->
    <Border Padding="12,6,12,6"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SukiLightBorderBrush}">
        <StackPanel Spacing="3">

            <!-- Row 1: timestamp + level badge + component pill -->
            <StackPanel Orientation="Horizontal" Spacing="6">

                <!-- Timestamp -->
                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                           FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                           FontSize="12"
                           Opacity="0.5"
                           VerticalAlignment="Center"
                           MinWidth="80"/>

                <!-- Level badge (colored pill matching SwiftUI levelBadge) -->
                <Border Background="{Binding LevelBackgroundHex}"
                        CornerRadius="4"
                        Padding="5,2"
                        MinWidth="36"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding LevelAbbreviation}"
                               Foreground="{Binding LevelForegroundHex}"
                               FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Component pill — hidden for Other/All components -->
                <Border Background="{DynamicResource SukiLightBorderBrush}"
                        CornerRadius="4"
                        Padding="5,2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsComponentVisible}">
                    <TextBlock Text="{Binding Component}"
                               FontSize="12"
                               FontWeight="Medium"
                               Opacity="0.7"/>
                </Border>

            </StackPanel>

            <!-- Row 2: message text -->
            <TextBlock Text="{Binding Message}"
                       FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                       FontSize="14"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       TextTrimming="CharacterEllipsis"/>

        </StackPanel>
    </Border>
</UserControl>
