<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EdgeStudio.ViewModels"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="EdgeStudio.Views.Database.DatabaseListingView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="280,*"
          Background="{DynamicResource DittoAppBackground}">

        <!-- SVG spans the full window as background layer -->
        <svg:Svg Grid.ColumnSpan="2"
                 Path="avares://EdgeStudio/Assets/Backgrounds/step_and_repeat_banner.svg"
                 Stretch="Fill"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" />

        <!-- ===================================================
             Column 0: Left sidebar
             =================================================== -->
        <Grid Grid.Column="0"
              Margin="32,0,24,0"
              RowDefinitions="3*,Auto,16,Auto,8,Auto,8,Auto,1*">

            <!-- Row 1: "Edge Studio" branding — directly above buttons -->
            <TextBlock Grid.Row="1"
                       Text="Edge Studio"
                       FontFamily="{StaticResource KairosSans}"
                       FontSize="38"
                       FontWeight="Bold"
                       Foreground="{DynamicResource DittoAccent}" />

            <!-- Row 3: + Database Config -->
            <Button Grid.Row="3"
                    Command="{Binding AddDatabaseCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,10"
                    Background="{DynamicResource DittoAccent}"
                    Foreground="Black"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <materialIcons:MaterialIcon Kind="Plus" Width="18" Height="18" />
                    <TextBlock Text="Database Config" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <!-- Row 5: Ditto Portal -->
            <Button Grid.Row="5"
                    Command="{Binding OpenDittoPortalCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,10"
                    Background="{DynamicResource DittoCardSurface}"
                    Foreground="{DynamicResource DittoCardText}"
                    CornerRadius="6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <materialIcons:MaterialIcon Kind="Cloud" Width="18" Height="18" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Ditto Portal"
                               Margin="8,0" VerticalAlignment="Center" />
                    <materialIcons:MaterialIcon Grid.Column="2" Kind="OpenInNew"
                                               Width="14" Height="14" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <!-- Row 7: Import from QR Code -->
            <Button Grid.Row="7"
                    Command="{Binding ImportFromQrCodeCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,10"
                    Background="{DynamicResource DittoCardSurface}"
                    Foreground="{DynamicResource DittoCardText}"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <materialIcons:MaterialIcon Kind="Qrcode" Width="18" Height="18" />
                    <TextBlock Text="Import from QR Code" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Row 8 (1*): bottom spacer -->

        </Grid>

        <!-- ===================================================
             Column 1: Right content panel (cards)
             =================================================== -->
        <Grid Grid.Column="1">

            <!-- Database cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="24,32,24,24">
                <ItemsControl ItemsSource="{Binding DatabaseConfigs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <suki:GlassCard IsInteractive="True" Margin="0"
                                            Cursor="Hand" Tapped="DatabaseCard_Tapped">
                                <suki:GlassCard.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Edit"
                                                  Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).EditDatabaseCommand}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Show QR Code"
                                                  Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).ShowQrCodeCommand}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Delete"
                                                  Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).DeleteDatabaseCommand}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </suki:GlassCard.ContextMenu>
                                <Grid ColumnDefinitions="Auto,*" Margin="4">
                                    <materialIcons:MaterialIcon Kind="Database"
                                                               Width="22" Height="22"
                                                               Foreground="{DynamicResource DittoAccent}"
                                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource DittoAccent}"
                                                   FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="•••••••••••••••"
                                                   FontSize="11" Opacity="0.5" />
                                    </StackPanel>
                                </Grid>
                            </suki:GlassCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel IsVisible="{Binding HasDatabaseConfigs}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="10" Opacity="0.7">
                <materialIcons:MaterialIcon Kind="DatabaseOff" Width="48" Height="48"
                                            HorizontalAlignment="Center" />
                <TextBlock Text="No database configurations registered"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Click '+ Database Config' to get started"
                           FontSize="13" HorizontalAlignment="Center" />
            </StackPanel>

        </Grid>

    </Grid>
</UserControl>
